# Cloudflare Tunnel 主站配置（health-primary）
# 在 Cloudflare Dashboard 创建 named tunnel 后，把 token 粘贴到这里。

TUNNEL_TOKEN=replace-with-health-primary-tunnel-token
TUNNEL_LOG_LEVEL=info
TUNNEL_METRICS=127.0.0.1:42101

# 如当前网络阻断 UDP / QUIC，可切到 http2（走 TCP 7844）
# TUNNEL_TRANSPORT_PROTOCOL=http2

# 如 PATH 中找不到 cloudflared，可显式指定
# CLOUDFLARED_BIN=/usr/local/bin/cloudflared
