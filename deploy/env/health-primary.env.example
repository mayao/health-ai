# Health AI 主站（公司局域网服务器）
# 复制到 deploy/.env.primary.local 后填写真实值，再用 DEPLOY_ENV_FILE 指向它。

NODE_ENV=production
PORT=3001
HOSTNAME=0.0.0.0
PUBLIC_BASE_URL=https://app.example.com
SYNC_SERVER_URL=https://app.example.com

HEALTH_AUTH_ENABLED=true
HEALTH_JWT_SECRET=replace-with-a-random-secret-at-least-32-chars
# 固定主账号（仅单人环境启用；必须同时配置 OWNER_DEVICE_ID，避免误归并）
# HEALTH_PINNED_USER_ID=user-self
# HEALTH_OWNER_DEVICE_ID=iphone-real-99990000

HEALTH_LOG_LEVEL=error
HEALTH_IMPORT_AUDIT_MODE=redacted
HEALTH_ALLOW_LOCAL_EXPORTS=0
HEALTH_ALLOW_LOCAL_DELETE=0
HEALTH_DATA_RETENTION_NOTE=导入原文件不入库，导入审计仅保留脱敏占位

HEALTH_LLM_PROVIDER=openai-compatible
HEALTH_LLM_MODEL=kimi-latest
HEALTH_LLM_BASE_URL=https://api.kimi.com/coding/v1
HEALTH_LLM_API_KEY=replace-with-runtime-secret
HEALTH_LLM_FALLBACK_KIMI_MODEL=kimi-latest
HEALTH_LLM_FALLBACK_KIMI_KEY=

# 可选：如果数据库不放在默认 data/ 目录，可显式指定
# HEALTH_DB_PATH=/opt/vital-command/data/health-system.sqlite

# 可选：设备 OAuth 回调会使用公网域名
# HUAWEI_HEALTH_CLIENT_ID=
# HUAWEI_HEALTH_CLIENT_SECRET=
# GARMIN_CLIENT_ID=
# GARMIN_CLIENT_SECRET=
# COROS_CLIENT_ID=
# COROS_CLIENT_SECRET=
