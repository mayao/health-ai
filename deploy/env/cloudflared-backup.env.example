# Cloudflare Tunnel 备站配置（health-backup）

TUNNEL_TOKEN=replace-with-health-backup-tunnel-token
TUNNEL_LOG_LEVEL=info
TUNNEL_METRICS=127.0.0.1:42102

# 如当前网络阻断 UDP / QUIC，可切到 http2（走 TCP 7844）
# TUNNEL_TRANSPORT_PROTOCOL=http2

# 如 PATH 中找不到 cloudflared，可显式指定
# CLOUDFLARED_BIN=/opt/homebrew/bin/cloudflared
